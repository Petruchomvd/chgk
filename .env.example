# === LLM-провайдеры ===

# Groq (бесплатный cloud, rate-limited)
# Получить: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# OpenAI (GPT-4o-mini: $0.15/1M input, $0.60/1M output)
# Получить: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Anthropic (Claude Haiku: $0.80/1M input, $4.00/1M output)
# Получить: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Google Gemini (Flash: $0.10/1M input, $0.40/1M output)
# Получить: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-key-here

# === Telegram-уведомления (опционально) ===
CHGK_TG_BOT_TOKEN=your-bot-token
CHGK_TG_CHAT_ID=your-chat-id
