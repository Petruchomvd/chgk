# === LLM providers ===

# Groq
GROQ_API_KEY=gsk_your_key_here

# OpenAI
OPENAI_API_KEY=sk-your-key-here

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Google Gemini
GOOGLE_API_KEY=your-key-here

# === Telegram training bot ===

# The current bot entrypoint accepts either TG_DIGEST_BOT_TOKEN or CHGK_BOT_TOKEN.
# Keep one of them set for the training bot.
TG_DIGEST_BOT_TOKEN=your-training-bot-token
# CHGK_BOT_TOKEN=your-training-bot-token

# Comma-separated Telegram user ids allowed to use the bot in private chat.
# Example: CHGK_BOT_ALLOWED_TG_IDS=477617262,123456789,987654321
CHGK_BOT_ALLOWED_TG_IDS=

# Optional legacy owner id:
# - included into the allowlist automatically
# - used to attach old single-user training.db progress during migration
CHGK_BOT_OWNER_TG_ID=

# === Telegram notifications / digests (optional) ===
CHGK_TG_BOT_TOKEN=your-notifier-bot-token
CHGK_TG_CHAT_ID=your-chat-id
